{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Flask: KayHomes",
      "type": "debugpy",
      "request": "launch",
      "module": "flask",
      "cwd": "${workspaceFolder}",
      "env": {
        "FLASK_APP": "starter.py",
        "FLASK_ENV": "development",
        "FLASK_DEBUG": "1"
      },
      "args": [
        "run"
      ],
      "jinja": true,
      "justMyCode": true
    }
  ]
}
